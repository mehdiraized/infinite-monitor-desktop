default_platform(:mac)

platform :mac do
  desc "Upload signed .pkg to Mac App Store via App Store Connect API"
  lane :upload_mas do
    # Prefer the exact path passed by submit-to-store.js, fall back to glob
    project_root = File.expand_path("..", __dir__)
    pkg_path = ENV["MAS_PKG_PATH"]
    unless pkg_path && File.exist?(pkg_path)
      pkg_path = Dir["#{project_root}/dist/infinite-monitor-*.pkg"].first
    end
    UI.user_error!("No .pkg file found in dist/. Make sure build:mac:store ran successfully.") unless pkg_path
    UI.message("Uploading #{pkg_path} to App Store Connect...")

    # Build the api_key hash from environment variables
    api_key = app_store_connect_api_key(
      key_id:        ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id:     ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_content:   ENV["APP_STORE_CONNECT_API_KEY"],  # raw .p8 content (not base64)
      is_key_content_base64: false
    )

    upload_to_testflight(
      pkg:                             pkg_path,
      api_key:                         api_key,
      skip_waiting_for_build_processing: false,  # wait so the build is ready in TestFlight
      uses_non_exempt_encryption:      false,    # no export-regulated encryption → skips France/EAR prompt
      distribute_external:             false,    # internal testers only; set true + add groups for external
      notify_external_testers:         false
    )

    UI.success("Successfully uploaded to TestFlight!")
  end
end
